use {re} from "re";
use {json} from "json";
use {dt} from "datetime";
use {p} from "path";
fn main() {
    print("Now: " + dt.now());
    print("Year: " + str(dt.year(123)));
    print("Formatted: " + dt.format(123, "%Y-%m-%d %H:%M:%S"));
    print("Join: " + p.join("a", "b", "c.txt"));
    print("Dirname: " + p.dirname("a/b/c.txt"));
    print("Basename: " + p.basename("a/b/c.txt"));
    print("Extension: " + p.extension("a/b/c.txt"));
}
