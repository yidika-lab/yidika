use {fs, sys} from "io";
use {cos, sin, sqrt, abs, max, pow, rand} from "math";
use {dt} from "datetime";
use {p} from "path";
use {b} from "base64";
use {regex} from "regex";
use {json} from "json";
fn main() {
    print("OS: " + sys.platform());
    fs.write("test_hello.txt", "Hello");
    content: str = fs.read("test_hello.txt");
    print("Read back: " + content);
    print("cos(0) = " + str(cos(0)));
    msg: str = "hello world";
    print("Upper: " + msg.toUpper());
    print("Trim: '" + "  spaced  ".trim() + "'");
    items: auto = [3, 1, 4];
    items.sort();
    print(str(items));
}
