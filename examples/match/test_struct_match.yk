struct Point { x: int; y: int }
struct Pair { a: Point; b: int }

fn main() {
    // Pattern matching simple sur struct
    p = Point { x: 3, y: 0 };

    desc0 = match p {
        Point { x: 0, y: 0 } => "origin",
        Point { x: 0, y }   => "on y-axis",
        Point { x, y: 0 }   => "on x-axis",
        Point { x, y }      => f"({x}, {y})"
    };
    println(desc0);

    // Nested Destruct (struct dans struct)
    pp = Pair { a: Point { x: 1, y: 2 }, b: 42 };

    desc1 = match pp {
        Pair { a: Point { x: 0, y }, b } => "x is zero",
        Pair { a: { x, y: 0 }, b }       => "y is zero in inner point",
        Pair { a: { x, y }, b }          => f"({x}, {y}) with {b}"
    };
    println(desc1);

    // Destruct avec binding
    p2 = Point { x: 5, y: 10 };
    desc2 = match p2 {
        Point { x: 5, y } => "x is 5, y is 10",
        _                 => "other"
    };
    println(desc2);
}
