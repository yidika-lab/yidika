fn fibonacci(n: int) -> int {
    if (n <= 1) { return n; }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

fn factorial(n: int) -> int {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}

fn main() {
    
    print(fibonacci(10));
    print(factorial(5));
    print(fibonacci(20));
    print(factorial(10));
    print(factorial(10));
    print(factorial(10));
    print(factorial(10));
    a:int = 3;

    b:int = a;
}
